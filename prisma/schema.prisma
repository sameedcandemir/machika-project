generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" 
}

model Product {
  id          Int            @id @default(autoincrement())
  productCode String         @unique
  name_tr     String
  name_en     String
  name_ar     String
  priceUSD    Float
  priceTRY    Float          @default(0) 
  stockStatus Int            @default(1)
  
  // 🗑️ ESKİ SİSTEMDEN KALDIRILANLAR:
  // imageUrl ve colors satırlarını sildik çünkü artık ayrı tablodalar.
  
  sizes       String         @default("Seri 1") 
  category    String         @default("Genel")    
  productType String         @default("Giyim")    
  brand       String         @default("MUTΛ")     
  createdAt   DateTime       @default(now())

  // 🎨 YENİ: Ürüne ait renk varyasyonları
  colors      ProductColor[]

  // Bu ürünün bulunduğu sipariş detayları
  orderItems  OrderItem[]
}

// 🎨 YENİ TABLO: ÜRÜN RENKLERİ VE RESİMLERİ
model ProductColor {
  id          Int      @id @default(autoincrement())
  productId   Int
  
  // Ürün silindiğinde o ürüne ait renkler ve resimler de silinsin (Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  colorName   String   // Adminin gireceği isim (Örn: "Kırmızı", "Saks Mavisi")
  colorHex    String?  // Mobilde renk yuvarlağı göstermek için (Örn: "#FF0000")
  
  // Müşterinin istediği 2 adet görsel alanı:
  image1      String?  // 1. Görselin URL'i
  image2      String?  // 2. Görselin URL'i
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  otpCode   String?
  role      String   @default("CUSTOMER")
  createdAt DateTime @default(now())

  // Bu müşterinin verdiği siparişler
  orders    Order[]
}

// 📦 SİPARİŞ ANA BİLGİLERİ
model Order {
  id          Int         @id @default(autoincrement())
  orderCode   String      @unique // Örn: SIP-1001
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  totalPrice  Float       // Toplam sepet tutarı
  currency    String      @default("TRY") // TRY veya USD
  status      String      @default("BEKLIYOR") // BEKLIYOR, ONAYLANDI, IPTAL
  createdAt   DateTime    @default(now())
  
  items       OrderItem[]
}

// 🛍️ SİPARİŞİN İÇİNDEKİ ÜRÜNLER
model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade) 
  
  size        String   // Seçilen seri (Örn: "2")
  color       String   // Seçilen renk ismi veya hex kodu (Örn: "Saks Mavisi")
  quantity    Int      // Toplam adet
  unitPrice   Float    // Satın alındığı andaki fiyat
}