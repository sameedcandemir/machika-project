generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" 
}

model Product {
  id                 Int            @id @default(autoincrement())
  productCode        String         @unique
  name_tr            String
  name_en            String
  name_ar            String
  priceUSD           Float
  priceTRY           Float          @default(0) 
  stockStatus        Int            @default(1)
  
  // 🚀 YENİ: İndirim Yüzdesi (Varsayılan olarak 0 yani indirim yok)
  discountPercentage Int            @default(0)
  
  sizes              String         @default("Seri 1") 
  category           String         @default("Genel")    
  productType        String         @default("Giyim")    
  brand              String         @default("MUTΛ")     
  createdAt          DateTime       @default(now())

  colors             ProductColor[]
  orderItems         OrderItem[]
}

model ProductColor { 
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) 
  
  colorName String   
  colorHex  String?  
  image1    String?  
  image2    String?  
  // 🚀 YENİ: 3, 4 ve 5. Fotoğraf Sütunları Eklendi
  image3    String?  
  image4    String?  
  image5    String?  
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  otpCode   String?
  role      String   @default("CUSTOMER")
  createdAt DateTime @default(now()) 
  orders    Order[]
}

model Order {
  id         Int         @id @default(autoincrement())
  orderCode  String      @unique 
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  totalPrice Float        
  currency   String      @default("TRY") 
  status     String      @default("BEKLIYOR") 
  createdAt  DateTime    @default(now()) 
  items      OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int 
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) 
  
  size      String   
  color     String   
  quantity  Int      
  unitPrice Float    
}

// Kategori Modeli
model Category {
  id        String   @id @default(uuid())
  title     String   @unique
  keyword   String   @unique
  createdAt DateTime @default(now())
}